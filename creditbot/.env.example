APP_NAME=CrediBot
APP_ENV=development
APP_DEBUG=true
APP_PUBLIC_URL=https://your-public-domain.com

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis (opcional; sin URL usa memoria local)
REDIS_URL=
REDIS_SESSION_TTL_SECONDS=3600

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.5
OPENAI_ENABLE_AI=true

# Proveedor WhatsApp: twilio (recomendado) | meta
WHATSAPP_PROVIDER=twilio

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_VALIDATE_SIGNATURE=false

# Meta WhatsApp Cloud API (opcional, solo si WHATSAPP_PROVIDER=meta)
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_VERIFY_TOKEN=
META_WHATSAPP_APP_SECRET=
META_GRAPH_API_VERSION=v21.0

DEFAULT_COUNTRY_CODE=593
ADMIN_DASHBOARD_PASSWORD=change-this-password

# Panel Streamlit (opcional: respaldo vía backend)
BACKEND_API_URL=https://credibot-uleam-gjj2.onrender.com
