# Plantilla de secretos para Streamlit Cloud / desarrollo local.
# Copia a dashboard/.streamlit/secrets.toml (NO subas valores reales al repo).

SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY = "your-service-role-key"
ADMIN_DASHBOARD_PASSWORD = "change-this-password"

# Twilio — obligatorio para responder desde Casos Derivados
TWILIO_ACCOUNT_SID = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN = "your-twilio-auth-token"
TWILIO_WHATSAPP_FROM = "whatsapp:+14155238886"

# Opcional: cerrar casos vía API si el backend también tiene Twilio
BACKEND_API_URL = "https://credibot-uleam-gjj2.onrender.com"
